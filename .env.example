# Public URL of the frontend (used for backend CORS allowlist).
# Comma-separate to allow multiple origins.
PUBLIC_WEB_URL=https://app.example.com

# Public URL of the GraphQL endpoint (baked into the frontend bundle at build time).
PUBLIC_API_URL=https://api.example.com/graphql

# Optional host port overrides for local `docker compose up`.
# (Coolify ignores these — it manages port mapping itself.)
FRONTEND_PORT=8080
BACKEND_PORT=4000
