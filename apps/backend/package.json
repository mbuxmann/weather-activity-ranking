    "hono": "^4.7.8",
    "p-retry": "^6.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.2"
  }
}
