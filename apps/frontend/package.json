    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contracts": "workspace:*",
    "graphql": "^16.11.0",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.74.0",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
