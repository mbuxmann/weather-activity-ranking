{
  "name": "weather-ranking-app",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run generate:gql && turbo build",
    "dev": "bun run generate:gql && turbo dev --filter=backend --filter=frontend",
    "generate": "bun run generate:gql",
    "generate:gql": "bun run --filter contracts generate && bun run --filter frontend generate",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
